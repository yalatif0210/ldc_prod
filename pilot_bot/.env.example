# ── Telegram ──────────────────────────────────────────────────────────────────
# Token obtenu via @BotFather (bot DIFFÉRENT du support_bot)
TELEGRAM_BOT_TOKEN=VOTRE_TOKEN_PILOT_BOT_ICI
TELEGRAM_BOT_USERNAME=ldc_pilot_bot

# URL publique du webhook — doit pointer vers /pilot/webhook/<TOKEN>
BASE_URL=https://ldc.lhspla-ci.org/pilot

# ── Sécurité : accès restreint aux chefs de projet ────────────────────────────
# Chat IDs Telegram autorisés, séparés par virgules
# Envoyer /id au bot pour obtenir son propre chat_id
AUTHORIZED_CHAT_IDS=123456789,987654321

# ── Base de données lab_db (READ ONLY) ────────────────────────────────────────
# Connexion à lab_db — user avec droits SELECT uniquement
LAB_DB_URL=postgresql://postgres:VOTRE_MOT_DE_PASSE@lab_db:5432/lab_db

# ── Flask ────────────────────────────────────────────────────────────────────
FLASK_DEBUG=false
SECRET_KEY=GENERER_UNE_CLE_ALEATOIRE_ICI

# ── Préférences ───────────────────────────────────────────────────────────────
TIMEZONE=Africa/Abidjan
SESSION_TTL_SECONDS=1800
